# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/career-links
MONGODB_PROD_URI=mongodb+srv://username:password@cluster.mongodb.net/career-links

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRY=30d

# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password

# Admin Configuration
ADMIN_EMAIL=admin@careerlinks.com
ADMIN_PASSWORD=admin_password_change_this

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Pagination
ITEMS_PER_PAGE=10
